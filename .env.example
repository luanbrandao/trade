# Binance — create API key with SPOT TRADING only, no withdraw, with IP whitelist
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_EFFORT=medium               # low | medium | high | max

# Trading config
TRADE_MODE=dryrun                  # dryrun | live | backtest
TRADE_AMOUNT_USD=50                # quote qty per trade
MIN_CONFIDENCE=70                  # 0-100, Claude decision threshold
MIN_RR_RATIO=2.0                   # min reward/risk ratio
COOLDOWN_MINUTES=30                # min minutes between trades on same symbol
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
LOOP_INTERVAL_MINUTES=15

# Safety gate — required for live mode
I_UNDERSTAND_RISKS=no

# Storage
DB_PATH=./data/trade.db

# Logging
LOG_LEVEL=info                     # debug | info | warn | error

# Notifications (optional — leave blank to disable)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_ON=executed,error           # csv: executed | error | summary | skipped
