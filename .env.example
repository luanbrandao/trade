# Binance — create API key with SPOT TRADING only, no withdraw, with IP whitelist
BINANCE_API_KEY=
BINANCE_API_SECRET=

# LLM provider selection
LLM_PROVIDER=anthropic             # anthropic | openai | gemini | deepseek

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_EFFORT=medium               # low | medium | high | max

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=                  # or DEEPSEEK
DEEPSEEK_MODEL=deepseek-chat       # deepseek-chat | deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Trading config
TRADE_MODE=dryrun                  # dryrun | live | backtest
TRADE_AMOUNT_USD=50                # quote qty per trade (used when SIZING_MODE=fixed)
SIZING_MODE=fixed                  # fixed | risk | atr
RISK_PCT_PER_TRADE=1.0             # % of account equity risked per trade (risk/atr modes)
ACCOUNT_EQUITY_USD=1000            # used by risk/atr sizing
ATR_MULTIPLIER=2.0                 # used by atr sizing (stop = entry - ATR * mult)
MAX_PORTFOLIO_HEAT_PCT=6.0         # cap total open risk across all positions
MIN_CONFIDENCE=70                  # 0-100, Claude decision threshold
MIN_RR_RATIO=2.0                   # min reward/risk ratio
COOLDOWN_MINUTES=30                # min minutes between trades on same symbol
STRATEGY_NAME=ema9_21+claude_v1    # tag persisted on trades/decisions for cross-strategy comparison
MAX_DAILY_LOSS_PCT=3.0             # paper-trading daily drawdown cap (% of accountEquity)
MAX_DAILY_LOSSES=3                 # consecutive-loss streak cap per UTC day
DRYRUN_MAX_HOLD_HOURS=168          # timeout for dryrun trades that never hit TP/SL (7d)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
LOOP_INTERVAL_MINUTES=15

# Safety gate — required for live mode
I_UNDERSTAND_RISKS=no

# Storage
DB_PATH=./data/trade.db

# Logging
LOG_LEVEL=info                     # debug | info | warn | error

# Notifications (optional — leave blank to disable)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_ON=executed,error           # csv: executed | error | summary | skipped

# --- Dashboard (paper, single-user) ---
DASHBOARD_PORT=8787              # uncommon port, low collision
DASHBOARD_HOST=0.0.0.0          # use 127.0.0.1 if behind an SSH tunnel
DASHBOARD_PATH_PREFIX=          # optional secret path, e.g. /dash-x7k9q2 (access WITH trailing slash)
DASHBOARD_AUTOSTART_LOOP=false  # if true, dashboard spawns the loop on boot
