{
  "name": "trade",
  "version": "0.1.0",
  "description": "Spot trading bot — Claude + Binance",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "test-binance-public": "ts-node src/scripts/test-binance-public.ts",
    "test-binance-private": "ts-node src/scripts/test-binance-private.ts",
    "test-claude": "ts-node src/scripts/test-claude.ts",
    "dryrun": "ts-node src/cli.ts dryrun",
    "live": "ts-node src/cli.ts live",
    "once": "ts-node src/cli.ts once",
    "monitor": "ts-node src/cli.ts monitor",
    "backtest": "ts-node src/cli.ts backtest --symbol BTCUSDT --from 2025-01-01 --to 2025-04-01",
    "status": "ts-node src/cli.ts status"
  },
  "dependencies": {
